{
  "name": "@ai-agent-ledger/sdk",
  "version": "0.1.0",
  "description": "Runtime observability, policy enforcement, and audit trails for AI agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentledger/agent-ledger-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/agentledger/agent-ledger-sdk/issues"
  },
  "homepage": "https://github.com/agentledger/agent-ledger-sdk#readme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "observability",
    "audit",
    "policy",
    "governance",
    "llm",
    "langchain"
  ],
  "license": "MIT",
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
